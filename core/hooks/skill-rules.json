{
  "rules": [
    {
      "skill": "/audit",
      "triggers": ["website audit", "site audit", "audit website", "check website", "start audit", "security check website", "audit the site", "web audit"],
      "exclude": ["project-audit", "astro-audit", "repo audit", "code audit"]
    },
    {
      "skill": "/project-audit",
      "triggers": ["project-audit", "project audit", "repo audit", "code audit", "check project", "audit repo", "repository audit", "check codebase"],
      "exclude": ["website audit", "site audit", "web audit"]
    },
    {
      "skill": "/adversarial-review",
      "triggers": ["review", "code review", "critical review", "adversarial", "plan review", "audit review", "find problems", "what's wrong"],
      "exclude": ["commit review", "pr review"]
    },
    {
      "skill": "/audit-orchestrator",
      "triggers": ["full audit", "check everything", "complete audit", "all audits", "comprehensive audit", "audit everything", "thorough audit"],
      "exclude": []
    },
    {
      "skill": "/capture-pdf",
      "triggers": ["capture", "pdf", "screenshot", "page as pdf", "capture pages", "print pages", "save as pdf"],
      "exclude": ["capture flag", "screenshot test"]
    },
    {
      "skill": "/lesson-learned",
      "triggers": ["lesson learned", "what did we learn", "learning", "remember this", "take note", "save learning", "extract lesson"],
      "exclude": []
    },
    {
      "skill": "/polish",
      "triggers": ["polish", "improve design", "make it better", "enhance", "beautify",
        "surprise me", "wow", "improve frontend", "boring", "generic",
        "too plain", "spice up", "level up", "aha effect", "wow effect", "quick wins"],
      "exclude": ["audit", "check", "design system"]
    },
    {
      "skill": "/design-system",
      "triggers": ["design system", "colors", "color palette", "typography", "font pairing", "spacing",
        "build component", "build landing page", "which colors", "ui components",
        "hero section", "hero", "navbar", "navigation", "footer", "card component",
        "pricing page", "pricing", "feature grid", "feature section", "testimonial",
        "contact form", "contact page", "about page", "landing page",
        "build page", "create page", "new page", "design page",
        "button style", "form design", "layout", "section",
        "color scheme", "dark mode", "light mode", "theme",
        "style guide", "brand colors", "industry palette",
        "glassmorphism", "gradient", "animation", "hover effect",
        "responsive design", "mobile design", "component library"],
      "exclude": ["audit", "lighthouse"]
    },
    {
      "skill": "/favicon-check",
      "triggers": ["favicon", "check favicon", "icon check", "app icon", "site icons"],
      "exclude": []
    },
    {
      "skill": "/meta-tags",
      "triggers": ["meta tags", "open graph", "og tags", "twitter card", "social preview", "structured data", "seo meta"],
      "exclude": []
    },
    {
      "skill": "/lighthouse-quick",
      "triggers": ["lighthouse", "pagespeed", "performance check", "core web vitals", "lcp", "cls", "fid", "speed check", "web vitals"],
      "exclude": []
    },
    {
      "skill": "/deploy-check",
      "triggers": ["deploy check", "deploy ready", "pre-deploy", "deployment check", "ready to deploy", "production ready", "before deploy"],
      "exclude": []
    },
    {
      "skill": "/git-hygiene",
      "triggers": ["git hygiene", "stale branches", "git cleanup", "branch cleanup", "git health", "clean branches", "git check"],
      "exclude": ["git status", "git diff"]
    },
    {
      "skill": "/audit-runner",
      "triggers": ["audit-runner", "autonomous audit", "auto audit", "audit in background", "unattended audit", "run audit automatically"],
      "exclude": []
    },
    {
      "skill": "/scan",
      "triggers": ["scan", "scan project", "detect stack", "tech stack", "what stack", "analyze project", "project profile", "what framework"],
      "exclude": ["secret scan", "security scan", "scan for"]
    },
    {
      "skill": "/security-scan",
      "triggers": ["security scan", "check security", "is this secure", "scan for secrets", "security audit", "before deploy security", "secret check", "mcp audit", "hook safety"],
      "exclude": ["auth audit", "deploy check"]
    },
    {
      "skill": "/consult",
      "triggers": ["consult", "improve project", "what should I fix", "project help", "project consultation", "optimize project", "upgrade project", "rebuild", "refactor project", "how to improve"],
      "exclude": ["audit", "review"]
    },
    {
      "skill": "/handoff",
      "triggers": ["handoff", "session handoff", "end session", "save progress", "switch context", "hand off", "continue later", "pass the baton", "wrap up session"],
      "exclude": []
    },
    {
      "skill": "/freshness-check",
      "triggers": ["freshness", "version check", "check versions", "outdated", "update check", "is everything current", "dependency versions"],
      "exclude": ["npm update", "npm install"]
    },
    {
      "skill": "/astro",
      "triggers": ["astro audit", "astro check", "astro migration", "astro upgrade", "astro version", "check astro"],
      "exclude": ["website audit", "project audit"]
    },
    {
      "skill": "/sveltekit",
      "triggers": ["sveltekit audit", "svelte audit", "svelte check", "svelte migration", "svelte 5", "sveltekit check", "svelte upgrade"],
      "exclude": ["website audit", "project audit"]
    },
    {
      "skill": "/database",
      "triggers": ["database audit", "db audit", "drizzle check", "schema audit", "migration check", "postgresql audit", "db check"],
      "exclude": ["website audit", "project audit"]
    },
    {
      "skill": "/auth",
      "triggers": ["auth audit", "auth check", "auth security", "login audit", "session audit", "password audit", "authentication check"],
      "exclude": ["website audit", "project audit"]
    },
    {
      "skill": "/review-team",
      "triggers": ["review team", "full review", "multi-review", "team review", "parallel review", "comprehensive review"],
      "exclude": ["code review", "plan review", "audit review"]
    },
    {
      "skill": "/debug-team",
      "triggers": ["debug team", "help me debug", "find the bug", "team debug", "debug this", "why is this broken"],
      "exclude": ["debug mode", "debug log"]
    },
    {
      "skill": "/security-team",
      "triggers": ["security team", "security audit team", "vulnerability scan", "team security", "pentest", "full security"],
      "exclude": ["security scan", "secret check"]
    },
    {
      "skill": "/hook-gen",
      "triggers": ["create hook", "add hook", "hook for", "generate hook", "when this happens", "new hook"],
      "exclude": ["hookify", "writing hooks"]
    },
    {
      "skill": "/export-rules",
      "triggers": ["export rules", "cursor rules", "windsurf rules", "copilot instructions", "convert rules", "mdc rules"],
      "exclude": ["rules distill"]
    }
  ]
}
